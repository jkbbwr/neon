/target/
/runtime/build/
_neon/
compile_flags.txt
.DS_Store

# Benchmark build outputs. Every language in bench/ compiles into its own tree
# (dotnet's `bin`/`obj` alone is ~90MB) and none of it is source.
bench/**/bin/
bench/**/obj/
bench/**/build/
bench/**/target/
bench/**/classes/
bench/brainfuck/c/bf
bench/brainfuck/cpp/bf
bench/brainfuck/go/bf
bench/brainfuck/zig/bf
bench/binary-trees/c/bt
bench/binary-trees/cpp/bt
bench/binary-trees/go/bt
bench/binary-trees/zig/bt
bench/word-frequency/c/wf
bench/word-frequency/cpp/wf
bench/word-frequency/go/wf
bench/word-frequency/zig/wf
bench/n-body/c/nb
bench/n-body/cpp/nb
bench/n-body/go/nb
bench/n-body/zig/nb
bench/*/*/bf_native
bench/*/*/bt_native
bench/*/*/wf_native
bench/*/*/nb_native

# Java compiles in place — no bin/ dir to catch these.
bench/**/*.class

# The bench runner caches per-language results between runs.
bench/**/.bench_cache.json
