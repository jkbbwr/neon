{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "neon",
      "camelcase": "Neon",
      "scope": "source.neon",
      "path": ".",
      "file-types": [
        "neon"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^neon$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Neon programming language"
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
