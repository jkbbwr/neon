{
  "name": "tree-sitter-neon",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Neon programming language",
  "keywords": [
    "parser",
    "tree-sitter",
    "neon"
  ],
  "license": "MIT",
  "files": [
    "grammar.js",
    "queries/*",
    "src/**",
    "tree-sitter.json"
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.0"
  },
  "tree-sitter": [
    {
      "scope": "source.neon",
      "file-types": [
        "neon"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^neon$"
    }
  ]
}
