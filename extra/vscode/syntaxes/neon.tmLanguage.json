{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Neon",
  "scopeName": "source.neon",
  "fileTypes": ["neon"],
  "patterns": [{ "include": "#code" }],
  "repository": {
    "code": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#annotations" },
        { "include": "#strings" },
        { "include": "#runes" },
        { "include": "#numbers" },
        { "include": "#atoms" },
        { "include": "#declarations" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#builtin-types" },
        { "include": "#type-names" },
        { "include": "#function-call" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.neon",
          "match": "///(?!/).*$"
        },
        {
          "name": "comment.line.double-slash.neon",
          "match": "//.*$"
        },
        { "include": "#block-comment" }
      ]
    },

    "block-comment": {
      "name": "comment.block.neon",
      "begin": "/\\*",
      "end": "\\*/",
      "patterns": [{ "include": "#block-comment" }]
    },

    "annotations": {
      "patterns": [
        {
          "comment": "The five annotations the compiler recognises, per compiler/src/expand.rs. Any argument that follows is left to the ordinary string and punctuation rules.",
          "match": "(@)(native|cfg|doc|runtime|pure)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.neon" },
            "2": { "name": "storage.modifier.annotation.neon" }
          }
        },
        {
          "comment": "An unrecognised annotation. The compiler rejects it; highlight it as an annotation anyway so the mistake is visible in context.",
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.neon" },
            "2": { "name": "invalid.deprecated.unknown-annotation.neon" }
          }
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.neon",
      "begin": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.neon" } },
      "end": "\"",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.neon" } },
      "patterns": [
        { "include": "#interpolation" },
        { "include": "#escapes" }
      ]
    },

    "interpolation": {
      "name": "meta.embedded.line.neon",
      "begin": "#\\{",
      "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.neon" } },
      "end": "\\}",
      "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.neon" } },
      "patterns": [
        { "include": "#interpolation-braces" },
        { "include": "#code" }
      ]
    },

    "interpolation-braces": {
      "comment": "A record literal inside a hole must find its own closing brace before the hole's.",
      "begin": "\\{",
      "beginCaptures": { "0": { "name": "punctuation.section.braces.begin.neon" } },
      "end": "\\}",
      "endCaptures": { "0": { "name": "punctuation.section.braces.end.neon" } },
      "patterns": [
        { "include": "#interpolation-braces" },
        { "include": "#code" }
      ]
    },

    "escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.unicode.neon",
          "match": "\\\\u\\{[0-9a-fA-F]{1,6}\\}"
        },
        {
          "name": "constant.character.escape.hex.neon",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "comment": "\\# escapes an interpolation, so \\#{ is a literal #{.",
          "name": "constant.character.escape.neon",
          "match": "\\\\[nrt0\\\\\"'#]"
        },
        {
          "name": "invalid.illegal.unknown-escape.neon",
          "match": "\\\\."
        }
      ]
    },

    "runes": {
      "patterns": [
        {
          "name": "constant.character.rune.neon",
          "match": "'(\\\\u\\{[0-9a-fA-F]{1,6}\\}|\\\\x[0-9a-fA-F]{2}|\\\\[nrt0\\\\\"']|[^'\\\\])'"
        },
        {
          "name": "invalid.illegal.rune.neon",
          "match": "'[^']*'"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.neon",
          "match": "\\b0[xX][0-9a-fA-F](_?[0-9a-fA-F])*\\b"
        },
        {
          "name": "constant.numeric.octal.neon",
          "match": "\\b0[oO][0-7](_?[0-7])*\\b"
        },
        {
          "name": "constant.numeric.binary.neon",
          "match": "\\b0[bB][01](_?[01])*\\b"
        },
        {
          "comment": "A float needs a digit after the dot, so `x.0` and `xs..1` stay unambiguous.",
          "name": "constant.numeric.float.neon",
          "match": "\\b[0-9](_?[0-9])*(\\.[0-9](_?[0-9])*)?([eE][+-]?[0-9](_?[0-9])*)?\\b(?![.a-zA-Z_])|\\b[0-9](_?[0-9])*\\.[0-9](_?[0-9])*([eE][+-]?[0-9](_?[0-9])*)?"
        },
        {
          "name": "constant.numeric.integer.neon",
          "match": "\\b[0-9](_?[0-9])*\\b"
        }
      ]
    },

    "atoms": {
      "comment": "`:name` is an atom only when the colon does not directly follow an identifier — that look-back is what keeps `{ x:y }` from meaning something different to `{ x: y }`. The leading `:` exclusion keeps `::` out.",
      "name": "constant.other.atom.neon",
      "match": "(?<![A-Za-z0-9_:]):[A-Za-z_][A-Za-z0-9_]*"
    },

    "declarations": {
      "patterns": [
        {
          "comment": "fn name, including the test/bench forms that take a name.",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.neon" },
            "2": { "name": "entity.name.function.neon" }
          }
        },
        {
          "comment": "mu type A = ... — an explicit recursive-type binder.",
          "match": "\\b(mu)\\s+(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.neon" },
            "2": { "name": "keyword.declaration.type.neon" },
            "3": { "name": "entity.name.type.neon" }
          }
        },
        {
          "comment": "opaque record / internal mod, and the plain forms of both.",
          "match": "\\b(?:(internal|opaque)\\s+)?(record|newtype|type|protocol|marker|mod)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.neon" },
            "2": { "name": "keyword.declaration.type.neon" },
            "3": { "name": "entity.name.type.neon" }
          }
        },
        {
          "match": "\\b(impl)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.impl.neon" },
            "2": { "name": "entity.name.type.neon" }
          }
        },
        {
          "match": "\\b(let|const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.variable.neon" },
            "2": { "name": "variable.other.neon" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.neon",
          "match": "\\b(fn|let|record|opaque|newtype|type|mu|protocol|marker|impl|where|use|mod|internal|const)\\b"
        },
        {
          "name": "keyword.control.neon",
          "match": "\\b(if|else|match|loop|while|for|in|break|continue|return)\\b"
        },
        {
          "name": "keyword.control.exception.neon",
          "match": "\\b(throws|throw|try|catch|orelse)\\b"
        },
        {
          "name": "keyword.other.test.neon",
          "match": "\\b(test|bench|assert|assert_eq|assert_ne|assert_throws)\\b"
        },
        {
          "comment": "Operators that are words. `and` binds tighter than `or`.",
          "name": "keyword.operator.word.neon",
          "match": "\\b(and|or|band|bor|bxor|bnot|bsl|bsr|is|as)\\b"
        },
        {
          "comment": "`enum` is deliberately not a keyword — sum types are unions of records — but the parser reports a dedicated diagnostic when it is used as a declaration, so flag it.",
          "name": "invalid.illegal.not-a-keyword.neon",
          "match": "\\benum(?=\\s+[A-Za-z_])"
        }
      ]
    },

    "constants": {
      "name": "constant.language.neon",
      "match": "\\b(null|true|false)\\b"
    },

    "builtin-types": {
      "comment": "The base types, answered by the checker rather than declared in a prelude, plus `any`, which is syntax.",
      "name": "support.type.builtin.neon",
      "match": "\\b(i64|f64|str|bool|any)\\b"
    },

    "type-names": {
      "comment": "A heuristic: an initial capital reads as a type or a record constructor. The server does not provide semantic tokens, so this is as far as highlighting can honestly go.",
      "name": "entity.name.type.neon",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },

    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.neon" }
      }
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.neon",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.neon",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.comparison.neon",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.neon",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.neon",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "comment": "`..` is record and list spread. There is no `..=`.",
          "name": "keyword.operator.spread.neon",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.other.neon",
          "match": "\\?|!|&|\\|"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.namespace.neon", "match": "::" },
        { "name": "punctuation.separator.colon.neon", "match": ":" },
        { "name": "punctuation.separator.comma.neon", "match": "," },
        { "name": "punctuation.terminator.neon", "match": ";" },
        { "name": "punctuation.accessor.neon", "match": "\\." },
        { "name": "punctuation.section.parens.neon", "match": "[()]" },
        { "name": "punctuation.section.brackets.neon", "match": "[\\[\\]]" },
        { "name": "punctuation.section.braces.neon", "match": "[{}]" }
      ]
    },

    "identifiers": {
      "name": "variable.other.neon",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
    }
  }
}
