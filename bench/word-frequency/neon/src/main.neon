// Word-frequency, as a benchmark: build a word per token and count occurrences in a
// string-keyed map. The cost is string construction, string hashing, and map
// insert/update — none of which the brainfuck or binary-trees benches touch.
//
// The input is generated, not read: a minstd LCG (multiplier 48271, modulus 2^31 - 1)
// whose products stay under 2^53, so every language — including the ones whose only
// numbers are doubles — computes the identical sequence with plain arithmetic. Each
// token is the word `w<id>` with `id = x % 10000`.
//
// No sort on output, deliberately: the stdlib has none, and a sort would benchmark the
// sort. The reported figures — distinct words, total tokens, and the highest count —
// are order-free, and the runner pins the exact line.

use std::io;
use std::collections::map;
use std::collections::list;

fn main() {
    let counts: Map[str, i64] = map::new();
    let x = 42;
    let n = 10000000;

    let i = 0;
    while i < n {
        x = (x * 48271) % 2147483647;
        let word = "w#{x % 10000}";
        counts = map::update(counts, word, 0, (v: i64) => v + 1);
        i = i + 1;
    };

    let vals = map::values(counts);
    let d = list::len(vals);
    let max = 0;
    let j = 0;
    while j < d {
        if vals[j] > max {
            max = vals[j];
        };
        j = j + 1;
    };

    io::println("Result: #{map::len(counts)} #{n} #{max}");
}
