// The other half of opacity: the *type* is public even though the contents are not. A
// value can be held in a local, passed to a function, returned, stored in a record and
// put in a list, all from outside the declaring module. Only reaching inside is closed.
//
// This is the property that makes the feature usable rather than merely restrictive: a
// handle travels wherever the program needs it and stays unforgeable the whole way.
//
// The rule is not "the declaring module alone", but it is close: an opaque record is
// visible within its declaring module's SUBTREE and nowhere else. A module nested inside
// the declaring one may reach in, because an `internal mod` is the implementation of the
// module around it and cannot be barred from the type it exists to implement —
// `std::fs::raw::guard` builds the `File` that `std::fs` declares, and `inner::wrap`
// below is that same shape. A parent may NOT reach into a type its child declared; it
// asks through a function the child exposes, exactly as `mint` does with `inner::value`.
// Note the nested type is never *named* from the root: `vault::inner::Secret` does not
// resolve there, which is a separate module-path limitation, so `vault` hands out its own
// single-level `Token` for the parts that need a type annotation.

use std::io;

internal mod vault {
    opaque record Token { code: i64 }

    internal mod inner {
        opaque record Secret { code: i64 }
        fn seal(n: i64) -> Secret { Secret { code: n } }

        // The accessor its parent has to go through: `vault` cannot read `Secret`'s
        // field itself, because a parent is outside its child's subtree.
        fn value(s: Secret) -> i64 { s.code }

        // A nested module reaching *outward* into the module that contains it. This is
        // the `internal mod raw` shape and the direction the stdlib actually uses: the
        // inner module is the implementation of the outer one, so it cannot be barred
        // from the type it exists to implement -- `std::fs::raw::guard` builds the
        // `File` that `std::fs` declares, exactly here.
        fn wrap(n: i64) -> Token { Token { code: n } }
    }

    // The parent asks through the child's accessor. Reading `s.code` directly here is
    // rejected: `vault` is outside `vault::inner`'s subtree, and being its parent buys
    // nothing.
    fn mint(n: i64) -> Token {
        let s = inner::seal(n);
        Token { code: inner::value(s) }
    }
    fn value(t: Token) -> i64 { t.code }
    fn minted_inside(n: i64) -> Token { inner::wrap(n) }
    fn bump(t: Token) -> Token { mint(value(t) + 1) }
}

// Holding one in a field is fine: the field is ours, its contents are not.
record Envelope { held: vault::Token, label: str }

fn main() {
    // Held, passed, returned.
    let t = vault::mint(41);
    io::println(to_string(vault::value(vault::bump(t))));

    // Stored in a record we own, then handed back out.
    let env = Envelope { held: vault::mint(7), label: "sealed" };
    io::println(env.label);
    io::println(to_string(vault::value(env.held)));

    // Built by a module nested inside the one that declares the type.
    io::println(to_string(vault::value(vault::minted_inside(3))));

    // Carried in a list.
    let many = [vault::mint(1), vault::mint(2)];
    for item in many {
        io::println(to_string(vault::value(item)));
    };
}
