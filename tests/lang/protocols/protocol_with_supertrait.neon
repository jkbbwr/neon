// A protocol may require another: `protocol Ranked for T where T: Named`.
// Implementing the sub-protocol obliges the type to implement the super one, and
// the super's methods are callable from inside the sub's impl and from any generic
// bounded on the sub alone.
//
// These protocols are declared here rather than taken from the prelude: comparison
// is structural (see docs/decisions.md), so the prelude has no Eq/Ord to borrow.

use std::io;
use std::string;

record Version { major: i64, minor: i64 }

protocol Named for T {
    fn name(v: T) -> str
}

protocol Ranked for T where T: Named {
    fn rank(v: T) -> i64
}

impl Named for Version {
    fn name(v: Version) -> str {
        string::concat(to_string(v.major), string::concat(".", to_string(v.minor)))
    }
}

impl Ranked for Version {
    fn rank(v: Version) -> i64 {
        v.major * 100 + v.minor
    }
}

// The bound is Ranked alone; Named comes with it.
fn describe[T](a: T, b: T) -> str where T: Ranked {
    let label = string::concat(name(a), string::concat(" vs ", name(b)));
    if rank(a) == rank(b) {
        string::concat(label, ": same")
    } else if rank(a) < rank(b) {
        string::concat(label, ": less")
    } else {
        string::concat(label, ": greater")
    }
}

fn main() {
    let v1 = Version { major: 1, minor: 0 };
    let v2 = Version { major: 1, minor: 2 };

    io::println(describe(v1, v1));
    io::println(describe(v1, v2));
    io::println(describe(v2, v1));
    io::println(name(v1));
}
