// `@inline` asks the C compiler to inline a function at every call site — and asks in the
// only way that works: `always_inline`, not a hint.
//
// A hint does nothing here. Measured on the brainfuck benchmark, where `list::set` is the
// hot loop's only write and was 23% of the profile: `__builtin_expect` on the cold branch
// moved it 3%, outlining the cold error path 4%, `static` linkage 0%. Forcing the inline
// moved it from 1.09s to 0.84s. gcc's own heuristics decline these wrappers, so an
// advisory annotation would read as though it did something and would not.
//
// It is for a *small wrapper around a primitive* — a bounds check and a call, where the
// call and its tagged-result return cost more than the body. That is why it is opt-in per
// declaration rather than a heuristic: asking for it on anything substantial trades size
// for nothing.
//
// Semantics are unchanged by it. That is the whole point of this file: an `@inline`
// function computes exactly what it would have computed, including through recursion,
// argument evaluation order, and being passed around as a value.

use std::io;
use std::collections::list;

@inline
fn double(x: i64) -> i64 { x * 2 }

@inline
fn clamp(x: i64, lo: i64, hi: i64) -> i64 {
    if x < lo { lo } else if x > hi { hi } else { x }
}

// A throwing `@inline` fn: the tagged-result return is exactly what makes inlining pay,
// so it must keep working through one.
@inline
fn checked(xs: List[i64], i: i64) throws IndexError -> i64 {
    try list::get(xs, i)
}

// Not annotated, and calls annotated ones: inlining is not contagious and not required.
fn combine(a: i64, b: i64) -> i64 { double(a) + clamp(b, 0, 10) }

fn main() {
    io::println("#{double(21)}");
    io::println("#{clamp(-5, 0, 10)} #{clamp(5, 0, 10)} #{clamp(50, 0, 10)}");
    io::println("#{combine(10, 99)}");

    // Through the stdlib's own `@inline` wrappers.
    let xs = list::repeat(7, 3);
    io::println("#{try! checked(xs, 0)} #{try! checked(xs, 2)}");

    // The throw path still throws — inlining does not flatten the error channel away.
    let missed = try? checked(xs, 99);
    io::println("#{missed orelse -1}");
}
