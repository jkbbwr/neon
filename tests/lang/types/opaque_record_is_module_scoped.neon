// `opaque` hides a record's fields, but not absolutely: they stay visible inside
// its own module and to a single parent module. Only beyond that is the record an
// atom — a name with no readable structure.
//
// That is why contractivity is judged where the `mu type` is declared. A
// recursive reference needs a guard: a position beneath a structural constructor.
// An opaque record's field is such a position exactly where the fields can be
// seen. So the identical declaration is well-formed here and rejected two modules
// out — see the sibling test opaque_record_is_an_atom_beyond_its_parent.
//
// An emptiness query is therefore module-relative, which is unusual and easy to
// forget.

use std::io;

mod rand {
    opaque record Rng { seed: Inner | null }

    // Inside the declaring module: `Rng` is a data constructor, and `seed` is a
    // position the recursion can sit in.
    mu type Inner = Rng
}

mod clock {
    opaque record Tick { at: Outer | null }
}

// One module out, in `clock`'s parent: still visible, still guarded.
mu type Outer = clock::Tick

fn main() {
    io::println("ok");
}
