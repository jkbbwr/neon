//@ compile-fail
//@ error-contains: Seed
//
// The sibling of opaque_record_is_module_scoped. `Rng` is two modules away, so
// its fields are not visible and it is an atom: a bare name with no position for
// a recursive reference to sit in.
//
// `Seed` therefore has no recursive occurrence at all, and a `mu type` that never
// names itself is an error — the binder asserts recursion that is not there. The
// identical declaration is well-formed inside `deep::rand` and inside `deep`.

mod deep {
    mod rand {
        opaque record Rng { seed: Seed | null }
    }
}

mu type Seed = deep::rand::Rng

fn main() {}
