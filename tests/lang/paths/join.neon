// `path::join(a, b)` resolves `b` against `a`.
//
// The rule worth knowing: an absolute `b` REPLACES `a` entirely. That mirrors passing
// an absolute argument to a command, where the working directory stops mattering — and
// it is why a caller that must not let `b` escape `a` has to check `is_absolute` first.
//
// Separators are neither doubled nor required, and an empty operand contributes
// nothing: joining nothing on must not change what the path names.

use std::io;
use std::path;

fn show(a: str, b: str) {
    io::println("#{a} + #{b} = #{path::join(a, b)}");
}

fn main() {
    show("a", "b");
    show("a/", "b");        // no doubled separator
    show("a///", "b");
    show("/a", "b");
    show("/", "b");         // the root is a base like any other
    show("///", "b");       // ...even written as several separators
    show("a", "b/c");
    show("a", "");          // empty tail: `a`, NOT `a/`
    show("", "b");          // empty base
    show("", "");
    show("/etc", "/tmp/x"); // absolute tail wins outright
    show("a", "/tmp/x");
    show("a", "..");        // `..` is not resolved here; that is `normalize`
    show("a", ".");

    // The escape hatch the absolute-replaces rule requires.
    let arg = "/etc/passwd";
    let safe = if path::is_absolute(arg) { "REFUSED" } else { path::join("/srv", arg) };
    io::println(safe);
}
