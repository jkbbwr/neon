// `parent` and `file_name` signal absence with `null`, like `string::find` and
// `list::last` — running out of path is an answer, not a failure, so neither throws.
//
// `parent("/")` is null rather than "/": the root is its own parent on POSIX, and
// returning it forever would turn a walk-upwards loop into a spin. `parent("a")` is
// null rather than "": the empty string is not a path anything accepts, and inventing
// "." would name a directory the caller never wrote. `orelse "."` if you want that.
//
// `file_name` is null when the last component is not a NAME — the root, or `..`.

use std::io;
use std::path;

fn show(p: str) {
    io::println("#{p} -> parent=#{path::parent(p) orelse "<null>"} name=#{path::file_name(p) orelse "<null>"}");
}

fn walk(p: str, n: i64) -> i64 {
    io::println("at #{p}");
    let up = path::parent(p);
    if up is null { n } else { walk(up as str, n + 1) }
}

fn main() {
    show("");
    show(".");
    show("/");
    show("///");
    show("a");            // a lone relative name has no parent
    show("a/b");
    show("/a");           // ...but an absolute one does: the root
    show("/a/b");
    show("/a/b/c.txt");
    show("a/b/");         // trailing separator is not a component
    show("a//b");
    show("a/./b");        // nor is `.`
    show("..");           // `..` is a component, but not a name
    show("a/..");
    show("../..");
    show("/..");
    show(".hidden");      // a leading dot is part of the name

    // The documented way to get cwd-relative behaviour out of a null parent.
    io::println(path::parent("a") orelse ".");

    // Walking upwards terminates, because the root reports no parent rather than
    // reporting itself. That is the property the null is for.
    io::println("steps=#{walk("/a/b/c", 0)}");
    io::println("steps=#{walk("a/b", 0)}");
}
