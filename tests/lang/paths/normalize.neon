// `path::normalize` resolves `.`, empty components and `..` LEXICALLY — no syscalls,
// so it never learns that a component was a symlink. On a path containing symlinks the
// result can name a different file than the input; that case wants a real `realpath`.
//
// The two decisions:
//   * `..` above the root is the root. POSIX defines `..` in `/` as `/`, so `/a/../..`
//     is `/` and the result names the directory the kernel would reach.
//   * `..` above a RELATIVE path survives. There is no working directory to resolve it
//     against without a syscall, so `../a` stays `../a` and dropping it would silently
//     change which file is named.
//
// A relative path that normalises to nothing is ".", not "" — normalize's job is to
// hand back a string usable as a path, and "" is not one.

use std::io;
use std::path;

fn show(p: str) {
    io::println("#{p} -> #{path::normalize(p)}");
}

fn main() {
    show("");             // the one place this module invents a component
    show(".");
    show("./.");
    show("/");
    show("//");
    show("///");          // a path that is only separators is the root
    show("a/b");
    show("a//b");
    show("a/b/");
    show("/a//b/./c/");
    show("./a/b");
    show("a/./b");

    // `..` popping.
    show("a/../b");
    show("/a/../b");
    show("a/b/../..");    // pops to nothing -> "."
    show("/a/b/../..");   // pops to nothing -> "/"

    // `..` above the root: clamped, because that is what POSIX means.
    show("/..");
    show("/../..");
    show("/a/../../..");
    show("/../a");

    // `..` above a relative path: kept, and they stack.
    show("..");
    show("../..");
    show("../a");
    show("a/../..");
    show("a/../../..");
    show("../a/../b");

    // Normalising is idempotent on everything above.
    io::println("#{path::normalize(path::normalize("/a/../../b//c/.")) == path::normalize("/a/../../b//c/.")}");

    // What normalize does NOT do: it is lexical, so it cannot save a `..` from
    // escaping a base. The check is a component-wise prefix test on the result.
    let base = "/srv/data";
    let want = path::normalize(path::join(base, "../../etc/passwd"));
    io::println("#{want} inside=#{path::starts_with(want, base)}");
}
