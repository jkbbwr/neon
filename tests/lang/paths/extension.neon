// `stem`, `extension` and `with_extension` split the FILE NAME at its last dot.
//
// Two rules keep the empty extension from ever existing:
//   * a leading dot is part of the name — `.bashrc` is a name, not an extension
//   * a trailing dot starts nothing — `a.` has no extension rather than an empty one
//
// So `extension` is either null or a non-empty string, and nothing downstream has to
// think about `""`.
//
// `with_extension` returns null where there is no name to attach an extension to,
// rather than handing back the input unchanged — that would report success for an
// operation that did not happen.

use std::io;
use std::path;

fn show(p: str) {
    io::println("#{p} -> stem=#{path::stem(p) orelse "<null>"} ext=#{path::extension(p) orelse "<null>"} md=#{path::with_extension(p, "md") orelse "<null>"} bare=#{path::with_extension(p, "") orelse "<null>"}");
}

fn main() {
    show("a.txt");
    show("/x/y/a.txt");
    show("a.tar.gz");     // the LAST dot wins: stem a.tar, ext gz
    show("README");       // no dot: the name is its own stem
    show(".bashrc");      // leading dot: part of the name
    show(".");            // no components at all
    show("..");           // a component, but not a name
    show("a.");           // trailing dot: no extension, and no empty one either
    show("a..b");
    show("/");
    show("");
    show("a/b.txt/");     // trailing separator ignored
    show("x/..");         // last component is not a name
    show("/x/.config");

    // with_extension replaces rather than appends, and keeps the directory.
    io::println(path::with_extension("/x/y/a.tar.gz", "bz2") orelse "<null>");
    // The opt-out for callers who genuinely do not care that it did nothing.
    io::println(path::with_extension("/", "md") orelse "/");
}
