// Iterating a list, two ways, in order.
//
//   1. index + `xs[i]` in a `loop` — the loop stops at `len`, so every index is
//      in range and the trap is never reached. This is exactly what `[]` is for:
//      the code has already established the element is there, so asserting presence
//      costs nothing and reads as nothing.
//   2. a `for` loop, the surface for element traversal. There is no iterator type
//      and no closure stream: a list is a contiguous buffer and `for` is a C loop
//      over it.
//
// Both visit every element exactly once, front to back. `fold` (a `Mappable`
// method) sums them without a mutable accumulator.

use std::io;
use std::string;
use std::collections::list;

fn main() {
    let xs: List[i64] = [3, 1, 4];

    let i = 0;
    loop {
        if i >= list::len(xs) { break; }
        io::println(string::concat("by index: ", to_string(xs[i])));
        i = i + 1;
    };

    for v in xs {
        io::println(string::concat("by for: ", to_string(v)));
    };

    let total = fold(xs, 0, (acc: i64, v: i64) => acc + v);
    io::println(string::concat("total: ", to_string(total)));

    // An empty list yields nothing at all: the `for` body never runs.
    let nothing: List[i64] = [];
    for v in nothing {
        io::println("empty: yielded something");
    };
    io::println(string::concat("empty len: ", to_string(list::len(nothing))));
}
