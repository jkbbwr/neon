//@ compile-fail
//@ error-contains: cannot be compared with `==`
//
// Equality is structural on primitives, `str`, records, tuples, lists, unions and maps.
// A closure is the one type it can never be: there is no structural answer to whether
// two functions are equal, and C cannot compare two `neon_closure` values either — this
// used to reach the C compiler, which rejected it with a message naming a generated
// temp file.
//
// So this is a permanent diagnostic rather than a gap. Compare whatever the closures
// were chosen by instead.

use std::io;

fn main() {
    let f = (x: i64) => x + 1;
    let g = (x: i64) => x + 1;
    io::println("#{f == g}");
}
