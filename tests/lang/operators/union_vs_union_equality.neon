// Two union-typed operands compare by tag, then by the payload that tag selects.
//
// Two traps live here. Two unions used to take a path that projected each side to
// its first variant and compared those, so `(i64 | bool)` operands compared an i64
// against a bool and `1 == true` was true. And a union compared against a *bare
// variant* did check the tag, but then compared the payload with a raw C `==` --
// fine while the variant was a scalar, and not valid C at all once it was a record,
// a tuple or a `str`, which the C compiler rejected outright.

use std::io;

record P { x: i64 }

fn pick(n: i64) -> i64 | bool { if n == 0 { 1 } else { true } }
fn word(n: i64) -> i64 | str { if n == 0 { 1 } else { "one" } }
fn rec(n: i64) -> P | :none { if n == 0 { P { x: 1 } } else { :none } }
fn text(n: i64) -> str | :none { if n == 0 { "hi" } else { :none } }
fn pair(n: i64) -> (i64, i64) | :none { if n == 0 { (1, 2) } else { :none } }

fn main() {
    // Different tags are unequal even when the payload bytes would match: `1` is not
    // `true`, though both are 1 in the payload.
    io::println("#{pick(0) == pick(1)}");
    io::println("#{pick(0) == pick(0)}");
    io::println("#{pick(1) == pick(1)}");

    // Same tag: the payload decides, through its own structural compare.
    io::println("#{word(1) == word(1)}");
    io::println("#{word(0) == word(1)}");
    io::println("#{word(0) != word(1)}");

    // A union against a bare variant: tag first, then the payload structurally. The
    // payload here is a record, a str and a tuple in turn -- none of which C can
    // compare with `==`.
    io::println("#{rec(0) == P { x: 1 }}");
    io::println("#{rec(0) == P { x: 2 }}");
    io::println("#{rec(1) == P { x: 1 }}");
    io::println("#{text(0) == "hi"}");
    io::println("#{pair(0) == (1, 2)}");
}
