// A `test` block is stripped from a normal build. Both blocks below would fail if
// anything ran them — the second one deliberately so — and the program must still print
// its two lines and exit 0.
//
// This is the half of `test` blocks a corpus file can pin: the harness runs the
// *program*, not the tests, so what it proves is that adding tests to a file does not
// disturb it. Whether the blocks run when asked is `cli/tests/test_verb.rs`.

use std::io;

test "would fail if it ran" {
    assert(1 + 1 == 3);
}

test "would also fail if it ran" {
    assert_eq("a", "b");
}

fn double(x: i64) -> i64 { x * 2 }

fn main() {
    io::println(to_string(double(21)));
    io::println("main ran");
}
