// Lexical path manipulation. POSIX separators, no filesystem.
//
// ---- A path is a `str`, not a `Path` ----
//
// `std::fs` already says "a path is a `str`", and this module does not change that. A
// `newtype Path = str` costs nothing at run time and was considered; it is not worth it
// here, for three reasons.
//
// A newtype earns its keep when the wrapped representation supports operations that are
// *wrong* for the new type -- `Bytes` exists because `to_upper` on a PNG is nonsense. A
// path is not like that. It is text, and every `std::string` operation on it is meaningful:
// `contains`, `starts_with`, `replace`, `split`, interpolation into a message. Wrapping it
// would make the useful operations the ones you have to cast away from.
//
// It would also not buy the safety it looks like it buys. The bugs in path code are wrong
// *values* -- an unnormalised `..`, a joined absolute path silently replacing its base, a
// prefix check done on bytes instead of components -- and a nominal wrapper catches none of
// them. What catches them is the behaviour specified below, which is available to a plain
// `str` just as well.
//
// Finally, `std::fs` takes `str`. A `Path` type this module could not force on `fs` would
// mean an `as str` at every single call site, which is friction bought with nothing. If
// `fs` ever grows a `Path` of its own, it belongs there, not here.
//
// ---- No syscalls ----
//
// Everything here is a pure function of the string. There is no `exists`, no
// `canonicalize`, no `cwd`, and `normalize` resolves `..` *lexically* -- it does not read
// the filesystem, so it cannot know that a component is a symlink, and on a path containing
// symlinks the normalised result may name a different file than the original. Where that
// matters you want a real `realpath`, which needs a syscall and is not this module.
//
// ---- POSIX only ----
//
// The separator is `/`, and only `/`. A backslash is an ordinary filename byte -- it is
// legal in a POSIX filename -- so `a\b` is one component, not two. There is no drive-letter
// handling and no UNC handling. This module is wrong for Windows paths and does not pretend
// otherwise; a Windows implementation is a different set of rules, not a tweak to these.
//
// Bytes, not characters: everything is byte-oriented like `std::string`, which is fine
// because the only byte with meaning is `/` and UTF-8 never produces it as a continuation.

use std::string;
use std::collections::list;

// ---- the shape of a path ----

// Absolute iff it starts at the root. Nothing else makes a path absolute here: a leading
// `~` is a shell convention, not a path one.
fn is_absolute(p: str) -> bool {
    string::starts_with(p, "/")
}

fn is_relative(p: str) -> bool {
    !is_absolute(p)
}

// The meaningful parts of `p`, left to right, and the primitive the rest of this module is
// built on. An absolute path gets `"/"` as its first component; nothing else can produce a
// `"/"` component, so the root is distinguishable from a name.
//
// Three things are dropped, because none of them changes which file a path names:
//
//   * empty components, so repeated separators collapse -- `a//b` is `["a", "b"]`
//   * a trailing separator -- `a/b/` is `["a", "b"]`, same as `a/b`
//   * `.` components -- `./a/./b` is `["a", "b"]`, and `.` alone is `[]`
//
// `..` is *kept*. It is not resolved here: `/a/../b` is `["/", "a", "..", "b"]`. Resolving
// it is `normalize`'s job, and keeping the two separate is what lets `starts_with` compare
// paths exactly as written.
//
// The empty string has no components. `components("")` and `components(".")` are both `[]`,
// which is the honest answer: neither names anything.
fn components(p: str) -> List[str] {
    let out: List[str] = [];
    if is_absolute(p) {
        out = list::push(out, "/");
    };
    for part in string::split(p, "/") {
        if !string::is_empty(part) and part != "." {
            out = list::push(out, part);
        };
    };
    out
}

internal mod raw {
    // Components back to a string. The inverse of `components` up to the things
    // `components` deliberately drops, so it round-trips a normalised path exactly.
    fn render(parts: List[str]) -> str {
        if list::is_empty(parts) {
            ""
        } else if parts[0] == "/" {
            string::concat("/", string::join(drop_first(parts), "/"))
        } else {
            string::join(parts, "/")
        }
    }

    fn drop_first(xs: List[str]) -> List[str] {
        let out: List[str] = [];
        let i = 1;
        while i < list::len(xs) {
            out = list::push(out, xs[i]);
            i = i + 1;
        };
        out
    }

    fn drop_last(xs: List[str]) -> List[str] {
        let out: List[str] = [];
        let i = 0;
        let n = list::len(xs);
        while i < n - 1 {
            out = list::push(out, xs[i]);
            i = i + 1;
        };
        out
    }

    // Strip every trailing separator. `"/"` becomes `""`; the caller decides what that
    // means, because for `join` it means the root and for nothing else does.
    fn trim_seps(s: str) -> str {
        let out = s;
        while string::ends_with(out, "/") {
            out = string::trim_end_of(out, "/");
        };
        out
    }

    // The byte offset of the dot that starts an extension, or `null`.
    //
    // The scan starts at 1 and stops before the last byte, which encodes both rules worth
    // having: a *leading* dot is part of the name, so `.bashrc` has no extension and is not
    // a nameless file with a `bashrc` one; and a *trailing* dot starts nothing, so `a.` has
    // no extension rather than an empty one. Ruling out the empty extension is why nothing
    // else in this module has to think about it.
    //
    // The last such dot wins: `a.tar.gz` is stem `a.tar`, extension `gz`.
    fn dot_at(name: str) -> i64 | null {
        let n = string::byte_len(name);
        let found: i64 | null = null;
        let i = 1;
        while i + 1 < n {
            if (try? string::char_at(name, i) orelse "") == "." {
                found = i;
            };
            i = i + 1;
        };
        found
    }
}

// ---- building ----

// `b` resolved against `a`.
//
// An absolute `b` *replaces* `a` entirely: `join("/etc", "/tmp/x")` is `/tmp/x`. This is
// the one surprising rule here and it is deliberate -- it is what makes `join(base, arg)`
// behave like passing `arg` to a command, where an absolute argument ignores the working
// directory. Check `is_absolute` first if a caller must not escape `a`.
//
// Separators are neither doubled nor required: `join("a/", "b")` and `join("a", "b")` are
// both `a/b`. An empty operand contributes nothing, so `join("a", "")` is `a` and not
// `a/` -- joining nothing on should not change what the path names.
fn join(a: str, b: str) -> str {
    if is_absolute(b) {
        b
    } else if string::is_empty(b) {
        a
    } else if string::is_empty(a) {
        b
    } else {
        let base = raw::trim_seps(a);
        if string::is_empty(base) {
            // `a` was nothing but separators: that is the root.
            string::concat("/", b)
        } else {
            string::concat(string::concat(base, "/"), b)
        }
    }
}

// Everything but the last component, or `null` when there is nothing left to name.
//
// `null` rather than a throw, and rather than `""`: asking for the parent of a path is
// ordinary, and running out of parents is an answer, not a failure. `parent("/")` is `null`
// -- the root is its own parent on POSIX, and returning `"/"` forever would turn a
// walk-upwards loop into a spin. `parent("a")` is also `null`: the empty string is not a
// path any syscall accepts, and inventing `"."` would name a directory the caller never
// wrote. Write `parent(p) orelse "."` if that is the meaning you want.
//
// Trailing separators and `.` do not count as components, so `parent("a/b/")` is `a` and
// `parent("a/./b")` is `a`. `..` does count, since it is not resolved: `parent("a/..")` is
// `a`, not `null`.
fn parent(p: str) -> str | null {
    let parts = components(p);
    if list::len(parts) <= 1 {
        null
    } else {
        raw::render(raw::drop_last(parts))
    }
}

// The last component, when it is a name.
//
// `null` when the path has no components (`""`, `"/"`, `"."`) and also when the last
// component is `".."` -- `a/..` names a directory, but not by name, and answering `".."`
// would hand back something no caller can use as a filename. Trailing separators are
// ignored, so `file_name("a/b/")` is `b`.
fn file_name(p: str) -> str | null {
    let last = list::last(components(p));
    if last is null {
        null
    } else {
        let name = last as str;
        if name == "/" or name == ".." {
            null
        } else {
            name
        }
    }
}

// The file name without its extension, or `null` wherever `file_name` is `null`. A name
// with no extension is its own stem: `stem("README")` is `README`, and `stem(".bashrc")` is
// `.bashrc`.
fn stem(p: str) -> str | null {
    let name = file_name(p);
    if name is null {
        null
    } else {
        let s = name as str;
        let at = raw::dot_at(s);
        if at is null {
            s
        } else {
            try? string::slice(s, 0, at as i64) orelse s
        }
    }
}

// The extension without its dot, or `null` when there is none. Never `""`: see
// `raw::dot_at` for why `a.` has no extension.
fn extension(p: str) -> str | null {
    let name = file_name(p);
    if name is null {
        null
    } else {
        let s = name as str;
        let at = raw::dot_at(s);
        if at is null {
            null
        } else {
            try? string::slice(s, (at as i64) + 1, string::byte_len(s))
        }
    }
}

// `p` with its extension replaced by `ext`, which is written *without* a leading dot:
// `with_extension("a/b.txt", "md")` is `a/b.md`. An empty `ext` removes the extension
// instead of leaving a trailing dot, so `with_extension("a/b.txt", "")` is `a/b`.
//
// `null` when there is no file name to attach an extension to -- `"/"`, `""`, `"a/.."`.
// The alternative was returning `p` unchanged, which silently reports success for an
// operation that did not happen; a caller that genuinely does not care can write
// `with_extension(p, e) orelse p` and say so.
fn with_extension(p: str, ext: str) -> str | null {
    let base = stem(p);
    if base is null {
        null
    } else {
        let b = base as str;
        let name = if string::is_empty(ext) { b } else { "#{b}.#{ext}" };
        raw::render(list::push(raw::drop_last(components(p)), name))
    }
}

// ---- normalising ----

// `p` with `.`, empty and repeated separators removed and `..` resolved against the
// components to its left. Purely lexical: nothing here touches the filesystem, so a `..`
// that crosses a symlink resolves to the wrong place. See the header.
//
// The two cases worth stating:
//
//   * `..` above the root is the root. `/..` and `/a/../..` are both `/`. This is not a
//     fudge -- POSIX defines `..` in `/` as `/` -- so the result names the same directory
//     the kernel would reach.
//   * `..` above a *relative* path is kept. `../a` stays `../a` and `a/../..` becomes `..`,
//     because without a working directory -- which needs a syscall -- there is nothing to
//     resolve them against, and dropping them would silently change which file is named.
//
// A relative path that normalises to nothing becomes `"."`, not `""`: `normalize("a/..")`,
// `normalize(".")` and `normalize("")` are all `"."`. This is the one place the module
// invents a component, and it does so because `normalize`'s whole job is to hand back a
// string that can be used as a path -- and `""` cannot be.
fn normalize(p: str) -> str {
    let abs = is_absolute(p);
    let out: List[str] = [];
    for part in components(p) {
        if part == ".." {
            let top = list::last(out);
            if top is null {
                // Nothing to pop. At the root `..` is the root, so it vanishes; relative,
                // it has to survive.
                if !abs {
                    out = list::push(out, "..");
                };
            } else if (top as str) == ".." {
                // Only reachable when relative: leading `..`s stack.
                out = list::push(out, "..");
            } else {
                out = raw::drop_last(out);
            };
        } else if part != "/" {
            out = list::push(out, part);
        };
    };
    if abs {
        string::concat("/", string::join(out, "/"))
    } else if list::is_empty(out) {
        "."
    } else {
        string::join(out, "/")
    }
}

// Is `prefix` a leading run of whole components of `p`?
//
// Component-wise, not byte-wise, which is the entire reason this exists rather than
// `string::starts_with`: `/foobar` does *not* start with `/foo`, though its bytes do. That
// distinction is the difference between a containment check and a sandbox escape.
//
// Compared as written -- `..` is not resolved on either side, so normalize both first if
// they may not be in the same form. The empty prefix is a prefix of everything, since it
// has no components to fail to match. An absolute prefix only matches an absolute path,
// because `"/"` is a component that only absolute paths have.
fn starts_with(p: str, prefix: str) -> bool {
    let a = components(p);
    let b = components(prefix);
    if list::len(b) > list::len(a) {
        false
    } else {
        let ok = true;
        let i = 0;
        while i < list::len(b) {
            if a[i] != b[i] {
                ok = false;
            };
            i = i + 1;
        };
        ok
    }
}
