// Choosing between two values.
//
// `max`/`min` order structurally and need `T: Ord` (see "Comparison is structural" and
// "Markers" in docs/decisions.md). The `_by` forms take the comparison as an argument
// and need no bound at all, which is the way to order a type whose meaningful order is
// not its structural one -- or one that has no structural order, like a `Map`.
//
// There is no overloading, so the two forms are two names rather than one.

fn max[T](a: T, b: T) -> T where T: Ord {
    if a < b { b } else { a }
}

fn min[T](a: T, b: T) -> T where T: Ord {
    if b < a { b } else { a }
}

// Ties go to `a`. All four functions here agree on that, matching `sort`'s stability:
// equal elements keep the order they came in.
fn max_by[T](a: T, b: T, cmp: (T, T) -> Ordering) -> T {
    if cmp(a, b) is :lt { b } else { a }
}

fn min_by[T](a: T, b: T, cmp: (T, T) -> Ordering) -> T {
    if cmp(b, a) is :lt { b } else { a }
}
