// Eager transformation over a one-parameter container `C[_]`. Every method returns a fresh
// `C` (or, for `fold`, the accumulated value): the language is immutable, so there is
// nothing lazy to thread and no iterator to allocate. A two-parameter type like
// `Map[K, V]` is not a functor over one parameter, so it iterates through
// `map::values`/`map::keys` first. See docs/design/stdlib.md.
//
// The impl below is not an orphan: this module declares `List` and owns the protocol.
// The list itself: nominal, covariant in `T`, and opaque -- the storage is native, so
// there is nothing to expose and nothing a caller could correctly build. Declared here
// rather than in the prelude so that THIS module owns it: opacity is decided by the
// declaring module's subtree, and the prelude's path is the root, which every program
// shares. See docs/design/opacity.md.
opaque record List[T] {}

protocol Mappable for C[_] {
    fn map[T, U](c: C[T], f: (T) -> U) -> C[U]
    fn filter[T](c: C[T], keep: (T) -> bool) -> C[T]
    fn fold[T, A](c: C[T], init: A, step: (A, T) -> A) -> A
}

impl Mappable for List {
    fn map[T, U](c: List[T], f: (T) -> U) -> List[U] {
        let out: List[U] = [];
        for x in c {
            out = push(out, f(x));
        };
        out
    }

    fn filter[T](c: List[T], keep: (T) -> bool) -> List[T] {
        let out: List[T] = [];
        for x in c {
            if keep(x) {
                out = push(out, x);
            };
        };
        out
    }

    fn fold[T, A](c: List[T], init: A, step: (A, T) -> A) -> A {
        let acc = init;
        for x in c {
            acc = step(acc, x);
        };
        acc
    }
}

// Immutable lists. Every operation returns a new list; these are values, which is what
// makes their generic argument covariant.
//
// The copy is not always paid for. A uniquely owned list (`rc == 1`) is updated in place,
// so `push` in a loop is amortised O(1) as long as the old binding is not kept. Hold on to
// the input as well and every `push` copies the whole list, which turns that loop
// quadratic -- the one performance cliff in this module worth knowing about.

@pure @native("neon_list_new") fn new[T]() -> List[T]
// Preallocate capacity for `n` elements to avoid regrowth while building. The list comes
// back EMPTY -- this reserves room, it does not produce elements. For `n` copies of a
// value, which is what a fixed-size buffer wants, use `repeat`.
@pure @native("neon_list_new_with_capacity") fn new_with_capacity[T](n: i64) -> List[T]
@pure @native("neon_list_len") fn len[T](xs: List[T]) -> i64

// Every element of `xs` replaced by `v`, keeping its length: resetting a buffer between
// passes without giving up the allocation it already has.
//
// Takes the list rather than a count, like everything else here: a constructor would be
// the only function in this module that is not `xs`-first, and "operations take a list and
// return a new one" is the shape the whole module is in. Building a sized buffer from
// nothing is `repeat`, which is a different job with a name that says which.
//
// The empty list fills to the empty list -- there is nothing to replace, which is the
// answer rather than an edge case.
//
// Written in Neon rather than as a native. `push` already retains `v` once per copy, so a
// native would reimplement the element witness handling for no asymptotic gain: the
// reservation means no regrowth and pushing into a uniquely owned list is in place, so
// this is one allocation and `len` writes.
fn fill[T](xs: List[T], v: T) -> List[T] {
    repeat(v, len(xs))
}

// `n` copies of `v`: the fixed-size buffer a tape, a grid row, a histogram or a sieve
// starts from. `new_with_capacity` does not do this -- it reserves room and hands back an
// empty list -- so without this the only way to get one is a `push` loop at every call
// site, which is a lot of ceremony for "ten zeroes".
//
// Argument order and name both follow `string::repeat(s, n)`: the thing first, the count
// second. It is the one constructor here that is not `xs`-first, which is why it is named
// for what it produces rather than for a list it does not have.
//
// `n <= 0` is the empty list rather than an error, matching `string::repeat` -- the
// natural reading of "zero copies", and it keeps this out of the `throws` machinery for a
// case every caller would have to handle and none would want to.
//
// Written in Neon rather than as a native. `push` already retains `v` once per copy, so a
// native would reimplement the element witness handling for no asymptotic gain: the
// reservation means no regrowth and pushing into a uniquely owned list is in place, so
// this is one allocation and `n` writes.
fn repeat[T](v: T, n: i64) -> List[T] {
    let out: List[T] = new_with_capacity(n);
    let i = 0;
    while i < n {
        out = push(out, v);
        i = i + 1;
    };
    out
}

// The unchecked primitives. A native cannot build the tagged result a throwing function
// returns, nor construct an `IndexError` -- both are program-specific layouts codegen owns.
// So the native does the unchecked operation and the check lives here, in the language,
// where the error record is declared and its message can name the offending index.
internal mod raw {
    @pure @native("neon_list_set") fn set_unchecked[T](xs: List[T], i: i64, v: T) -> List[T]
}

fn get[T](xs: List[T], i: i64) throws IndexError -> T {
    if i < 0 or i >= len(xs) {
        throw IndexError { message: "index #{i} out of range for length #{len(xs)}" };
    }
    xs[i]
}

fn set[T](xs: List[T], i: i64, v: T) throws IndexError -> List[T] {
    if i < 0 or i >= len(xs) {
        throw IndexError { message: "index #{i} out of range for length #{len(xs)}" };
    }
    raw::set_unchecked(xs, i, v)
}
@pure @native("neon_list_push") fn push[T](xs: List[T], v: T) -> List[T]
@pure @native("neon_list_concat") fn concat[T](a: List[T], b: List[T]) -> List[T]

// ---- sorting ----
//
// Merge sort, and deliberately so. A comparator can lie -- `sort` on a list holding
// NaN is the documented case, since NaN compares false against everything -- and an
// introsort-style algorithm can read past its bounds when that happens. Merging only
// ever advances an index it has already bounds-checked, so a lying comparator costs
// you a wrong order and nothing else.
//
// Stable: `merge` takes from the left whenever the two are equal, which is why the
// test is `cmp(b, a) is :lt` rather than `cmp(a, b) is :gt`.

fn sort[T](xs: List[T]) -> List[T] where T: Ord {
    sort_by(xs, (a: T, b: T) => if a < b { :lt } else if b < a { :gt } else { :eq })
}

fn sort_by[T](xs: List[T], cmp: (T, T) -> Ordering) -> List[T] {
    let n = len(xs);
    if n <= 1 {
        xs
    } else {
        let mid = n / 2;
        let left: List[T] = [];
        let right: List[T] = [];
        let i = 0;
        while i < mid {
            left = push(left, xs[i]);
            i = i + 1;
        };
        while i < n {
            right = push(right, xs[i]);
            i = i + 1;
        };
        merge(sort_by(left, cmp), sort_by(right, cmp), cmp)
    }
}

// Merge two lists that are each already sorted by `cmp`. `sort_by`'s combining step,
// exposed because it is useful on its own. Passing unsorted input is not an error and not
// checked; it just gives you an unsorted result.
fn merge[T](a: List[T], b: List[T], cmp: (T, T) -> Ordering) -> List[T] {
    let out: List[T] = [];
    let i = 0;
    let j = 0;
    while i < len(a) and j < len(b) {
        if cmp(b[j], a[i]) is :lt {
            out = push(out, b[j]);
            j = j + 1;
        } else {
            out = push(out, a[i]);
            i = i + 1;
        };
    };
    while i < len(a) {
        out = push(out, a[i]);
        i = i + 1;
    };
    while j < len(b) {
        out = push(out, b[j]);
        j = j + 1;
    };
    out
}

// ---- queries ----
//
// `contains` and `index_of` compare with `==`, which is structural on every type but a
// closure and needs no bound (equality is total by design -- see docs/decisions.md), so
// neither takes a `where`. Both walk the whole list even once the answer is settled: they
// are O(n) on a hit as well as a miss.

fn is_empty[T](xs: List[T]) -> bool {
    len(xs) == 0
}

// `null` rather than a throw: asking for the first element of a possibly-empty list is
// ordinary, and the caller usually has something to do in the empty case. `get` throws
// because an out-of-range *index* is a mistake; an empty list is not.
fn first[T](xs: List[T]) -> T | null {
    if is_empty(xs) { null } else { xs[0] }
}

fn last[T](xs: List[T]) -> T | null {
    if is_empty(xs) { null } else { xs[len(xs) - 1] }
}

fn contains[T](xs: List[T], v: T) -> bool {
    let found = false;
    for x in xs {
        if x == v {
            found = true;
        };
    };
    found
}

// The first index holding `v`, or `null`. Mirrors `string::find`, which answers the same
// question about bytes and returns the same shape.
fn index_of[T](xs: List[T], v: T) -> i64 | null {
    let at: i64 | null = null;
    let i = 0;
    for x in xs {
        if x == v and at is null {
            at = i;
        };
        i = i + 1;
    };
    at
}

// ---- transformations ----

fn reverse[T](xs: List[T]) -> List[T] {
    let out: List[T] = [];
    let i = len(xs);
    while i > 0 {
        i = i - 1;
        out = push(out, xs[i]);
    };
    out
}

// Half-open `[from, to)`, matching `string::slice` and `range`.
fn slice[T](xs: List[T], from: i64, to: i64) throws IndexError -> List[T] {
    if from < 0 or from > to or to > len(xs) {
        throw IndexError { message: "slice #{from}..#{to} out of range for length #{len(xs)}" };
    };
    let out: List[T] = [];
    let i = from;
    while i < to {
        out = push(out, xs[i]);
        i = i + 1;
    };
    out
}

// Monomorphic because there is no numeric bound to write and no overloading: `sum` over
// `i64` is the case that comes up.
fn sum(xs: List[i64]) -> i64 {
    let total = 0;
    for x in xs {
        total = total + x;
    };
    total
}
