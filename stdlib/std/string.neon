// String operations. `str` is UTF-8 bytes; indices and lengths are byte-oriented.
// Turning a value into a str is `to_string` (Display), not a function here.

@pure @native("neon_str_byte_len") fn byte_len(s: str) -> i64
@pure @native("neon_str_concat") fn concat(a: str, b: str) -> str
// The unchecked primitives. A native can return neither a tagged result nor an
// `i64 | null` -- both are layouts codegen generates per program -- so the check, the error
// and the union all live here, where the types are declared.
internal mod raw {
    @pure @native("neon_str_slice_unchecked") fn slice_unchecked(s: str, from: i64, to: i64) -> str
    @pure @native("neon_str_char_at_unchecked") fn char_at_unchecked(s: str, i: i64) -> str
    @pure @native("neon_str_index_of") fn index_of(s: str, needle: str) -> i64
    @pure @native("neon_str_is_int") fn is_int(s: str) -> bool
    @pure @native("neon_str_parse_int") fn parse_int(s: str) -> i64
}

fn slice(s: str, from: i64, to: i64) throws IndexError -> str {
    if from < 0 or from > to or to > byte_len(s) {
        throw IndexError { message: "slice #{from}..#{to} out of range" };
    }
    raw::slice_unchecked(s, from, to)
}

// The single *byte* at `i`, as a one-byte `str`. Byte-oriented like the rest of this
// module, so on a multi-byte character it hands back a fragment that is not valid UTF-8 on
// its own.
fn char_at(s: str, i: i64) throws IndexError -> str {
    if i < 0 or i >= byte_len(s) {
        throw IndexError { message: "index #{i} out of range" };
    }
    raw::char_at_unchecked(s, i)
}

// Thrown by `to_int`, which is the only thing here that parses.
record ParseError { message: str }
impl Display for ParseError { fn to_string(v: ParseError) -> str { v.message } }
impl Error for ParseError { fn message(v: ParseError) -> str { v.message } }

// An optional leading `+` or `-` and then digits, with nothing else allowed: no
// whitespace, no underscores, no radix prefix, so `to_int(" 1")` throws rather than
// trimming for you. A value too large for an `i64` wraps rather than throwing -- the
// digits are accumulated modulo 2^64 -- so range-check separately if the input is
// untrusted.
fn to_int(s: str) throws ParseError -> i64 {
    if !raw::is_int(s) {
        throw ParseError { message: "not an integer" };
    }
    raw::parse_int(s)
}
@pure @native("neon_str_join") fn join(parts: List[str], sep: str) -> str
// The byte offset of the first `needle`, or `null`. `null` rather than the C convention of
// `-1`: a sentinel index is a value the type system cannot stop you indexing with.
fn find(s: str, needle: str) -> i64 | null {
    let at = raw::index_of(s, needle);
    if at < 0 { null } else { at }
}
@pure @native("neon_str_contains") fn contains(s: str, needle: str) -> bool
@pure @native("neon_str_starts_with") fn starts_with(s: str, p: str) -> bool
@pure @native("neon_str_ends_with") fn ends_with(s: str, p: str) -> bool
@pure @native("neon_str_to_upper") fn to_upper(s: str) -> str
@pure @native("neon_str_to_lower") fn to_lower(s: str) -> str
@pure @native("neon_str_repeat") fn repeat(s: str, n: i64) -> str
@pure @native("neon_str_is_empty") fn is_empty(s: str) -> bool

// ---- splitting and trimming ----
//
// Written here rather than as natives: each returns a `List[str]` or builds one, and a C
// function cannot construct a list without the element's value-witness, which codegen
// generates per program. Same reason `range` lives in the prelude.

// The parts of `s` between each occurrence of `sep`, left to right. Adjacent separators
// yield empty parts, and a separator at either end yields an empty part there, so
// `split(",a,", ",")` is `["", "a", ""]` -- the inverse of `join`, which is the property
// worth preserving.
//
// An empty separator returns `[s]`. Splitting on nothing has no meaningful answer, and the
// alternatives are worse: a loop that never advances, or a silent per-byte split that
// would cut a multi-byte character in half.
fn split(s: str, sep: str) -> List[str] {
    if is_empty(sep) {
        [s]
    } else {
        let out: List[str] = [];
        let rest = s;
        let at = raw::index_of(rest, sep);
        while at >= 0 {
            out = std::collections::list::push(out, raw::slice_unchecked(rest, 0, at));
            rest = raw::slice_unchecked(rest, at + byte_len(sep), byte_len(rest));
            at = raw::index_of(rest, sep);
        };
        std::collections::list::push(out, rest)
    }
}

// Split on newlines, dropping a trailing `\r` so a CRLF file does not leave one on every
// line. A trailing newline does not produce a final empty line: `"a\n"` is `["a"]`, which
// is what reading a text file line by line should give. The empty string is no lines at
// all, `[]`, rather than one empty line.
fn lines(s: str) -> List[str] {
    let out: List[str] = [];
    if is_empty(s) {
        out
    } else {
        // Before the split rather than after: dropping the empty tail afterwards would
        // need a list slice, and this needs nothing.
        let body = trim_end_of(s, "\n");
        for part in split(body, "\n") {
            out = std::collections::list::push(out, trim_end_of(part, "\r"));
        };
        out
    }
}

internal mod raw_ws {
    // Space, tab, newline, carriage return. Byte-oriented, like everything else here: a
    // Unicode space is not trimmed, and the name would have to say so if it were.
    fn is_space(c: str) -> bool {
        c == " " or c == "\t" or c == "\n" or c == "\r"
    }
}

fn trim_start(s: str) -> str {
    let i = 0;
    let n = byte_len(s);
    while i < n and raw_ws::is_space(raw::char_at_unchecked(s, i)) {
        i = i + 1;
    };
    raw::slice_unchecked(s, i, n)
}

fn trim_end(s: str) -> str {
    let n = byte_len(s);
    while n > 0 and raw_ws::is_space(raw::char_at_unchecked(s, n - 1)) {
        n = n - 1;
    };
    raw::slice_unchecked(s, 0, n)
}

fn trim(s: str) -> str {
    trim_start(trim_end(s))
}

// Drop one trailing occurrence of `suffix`, if present. Not general trimming -- `lines`
// wants exactly this for `\r` and for the final newline.
fn trim_end_of(s: str, suffix: str) -> str {
    if !is_empty(suffix) and ends_with(s, suffix) {
        raw::slice_unchecked(s, 0, byte_len(s) - byte_len(suffix))
    } else {
        s
    }
}

// Every occurrence of `from` replaced by `to`, left to right and non-overlapping. An empty
// `from` matches nothing, for the same reason it does not split.
fn replace(s: str, from: str, to: str) -> str {
    if is_empty(from) {
        s
    } else {
        let out = "";
        let rest = s;
        let at = raw::index_of(rest, from);
        while at >= 0 {
            out = concat(out, raw::slice_unchecked(rest, 0, at));
            out = concat(out, to);
            rest = raw::slice_unchecked(rest, at + byte_len(from), byte_len(rest));
            at = raw::index_of(rest, from);
        };
        concat(out, rest)
    }
}
